{
  "name": "pvpa-flipbook",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma db push --skip-generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "node scripts/postinstall.js && (test -n \"$VERCEL\" && cp prisma/schema.postgresql.prisma prisma/schema.prisma && prisma generate || prisma generate)"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@vercel/blob": "^0.27.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.462.0",
    "next": "^14.2.0",
    "pdfjs-dist": "^4.6.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-pageflip": "^2.0.3",
    "sharp": "^0.33.5",
    "slugify": "^1.6.6",
    "tailwind-merge": "^2.5.0",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
