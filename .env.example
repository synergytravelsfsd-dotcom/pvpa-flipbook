# Database — use Vercel Postgres / Neon connection string in production
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/pvpa?sslmode=require"

# Public site URL (required for social share links and OG previews)
NEXT_PUBLIC_BASE_URL="https://your-app.vercel.app"

# Vercel Blob — auto-injected when Blob storage is linked to the project
# BLOB_READ_WRITE_TOKEN=""
